# PostgreSQL
DB_NAME=eduapp
DB_USERNAME=eduapp
DB_PASSWORD=eduapp

# JWT - generate a long random string for production, e.g. `openssl rand -base64 48`
JWT_SECRET=change-this-secret-in-production-please-make-it-long-and-random-32bytes+
JWT_EXPIRATION_MS=86400000
JWT_COOKIE_NAME=eduapp_token

# CORS - comma-separated list of origins allowed to call the API.
# Add your LAN IP (e.g. http://192.168.1.70:5173) to test from a phone on the same wifi.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookie: keep false for plain-HTTP local/LAN access. Set true only when served over real HTTPS.
COOKIE_SECURE=false
