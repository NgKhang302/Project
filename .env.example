# PostgreSQL
DB_NAME=eduapp
DB_USERNAME=eduapp
DB_PASSWORD=eduapp

# JWT - generate a long random string for production, e.g. `openssl rand -base64 48`
JWT_SECRET=change-this-secret-in-production-please-make-it-long-and-random-32bytes+
JWT_EXPIRATION_MS=86400000
JWT_COOKIE_NAME=eduapp_token

# CORS - origin of the frontend dev server / deployed frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173
