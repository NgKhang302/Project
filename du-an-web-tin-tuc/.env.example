# Copy file này thành .env rồi đổi giá trị thật khi deploy production.
# .env không được commit vào git (đã có trong .gitignore gốc).

# --- Dùng khi chạy bằng Docker: `docker compose up` ---
# docker-compose.yml tự đọc file .env cùng cấp để set 2 biến này.
POSTGRES_PASSWORD=postgres
JWT_SECRET=change-this-secret-in-production-must-be-long-enough

# --- Dùng khi chạy backend KHÔNG qua Docker: `./mvnw spring-boot:run` ---
# application.properties đọc DB_URL/DB_USERNAME/DB_PASSWORD qua ${DB_URL:...}.
# Lưu ý: Spring Boot không tự load file .env, phải export các biến này vào
# shell trước khi chạy, ví dụ: export $(grep -v '^#' .env | xargs)
DB_URL=jdbc:postgresql://localhost:5432/songnhip24_db
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
